# Copy to .env and adjust as needed. Never commit a real .env.
# Required values must be set; the rest have defaults in app/core/config.py.

# --- API metadata ---
APP_TITLE="Document Intelligence API"
APP_ENV=local

# --- Database (REQUIRED) ---
# Credential-free localhost default for local dev; use a real URL per environment.
# Also consumed by Alembic (migrations/env.py) as the single source of truth.
DATABASE_URL=postgresql+psycopg://localhost:5432/document_intelligence

# --- Redis / Celery broker (REQUIRED) ---
REDIS_URL=redis://localhost:6379/0

# --- Storage ---
# Root directory for local documents; holds originals/, extracted/, and exports/.
STORAGE_PATH=storage

# --- Worker settings ---
WORKER_CONCURRENCY=1
WORKER_QUEUE_NAME=document_intelligence
